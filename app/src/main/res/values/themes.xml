<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Main Application Theme -->
    <style name="Theme.WearableApplication"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primaryDark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondaryDark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primaryDark</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/background</item>

        <!-- Disable ActionBar Shadow -->
        <item name="elevationOverlayEnabled">false</item>

    </style>

    <style name="Theme.WearableApplication.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style
        name="Theme.WearableApplication.AppBarOverlay"
        parent="ThemeOverlay.MaterialComponents.Dark.ActionBar"/>

    <style
        name="Theme.WearableApplication.PopupOverlay"
        parent="ThemeOverlay.MaterialComponents.Light"/>

</resources>